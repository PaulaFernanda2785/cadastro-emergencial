APP_NAME="Cadastro Emergencial"
APP_ENV=local
APP_DEBUG=true
APP_FORCE_HTTPS=false
APP_URL=https://cadastroemergencial.local
APP_PUBLIC_URL=http://192.168.0.10
APP_TIMEZONE=America/Belem

DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=cadastro_emergencial
DB_USERNAME=root
DB_PASSWORD=
DB_CHARSET=utf8mb4
