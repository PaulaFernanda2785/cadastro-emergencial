SESSION_NAME=cadastro_emergencial_web_session_v2
SESSION_SAME_SITE=Lax
SESSION_IDLE_TIMEOUT_SECONDS=1800
IDEMPOTENCY_WINDOW_SECONDS=5

SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=cedecpa@defesacivilpa.com.br
SMTP_PASS=
SMTP_SECURE=ssl
SMTP_FROM_EMAIL=cedecpa@defesacivilpa.com.br
SMTP_FROM_NAME="Defesa Civil do Estado do Para"
